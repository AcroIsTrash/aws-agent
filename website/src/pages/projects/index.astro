---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order || b.data.startDate - a.data.startDate
);

const rendered = await Promise.all(
  projects.map(async (p) => ({ ...p, Content: (await p.render()).Content }))
);

const fmt = (d) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<BaseLayout
  title="Projects"
  description="Projects I'm building — AI agents, cloud infrastructure, and the tooling around them."
>
  <section class="page-head">
    <h1>Projects</h1>
    <p class="muted">
      Things I'm building — shipped ugly first, then improved in layers.
    </p>
  </section>

  <div class="projects">
    {rendered.map((p) => (
      <article id={p.slug} class="project">
        <div class="project-head">
          <h2>{p.data.title}</h2>
          <span class={`status status-${p.data.status}`}>{p.data.status}</span>
        </div>
        <p class="meta muted">Started {fmt(p.data.startDate)}</p>
        <p class="lead">{p.data.description}</p>
        <div class="tag-row">
          {p.data.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
        <div class="project-body">
          <p.Content />
        </div>
        {(p.data.repo || p.data.demo) && (
          <div class="project-links">
            {p.data.repo && (
              <a class="button secondary" href={p.data.repo}>View code</a>
            )}
            {p.data.demo && (
              <a class="button" href={p.data.demo}>Live demo</a>
            )}
          </div>
        )}
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .page-head { padding: 2.5rem 0 1.5rem; }
  .page-head h1 { margin-bottom: 0.4rem; }
  .projects { display: flex; flex-direction: column; gap: 1.25rem; }
  .project {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    box-shadow: var(--shadow);
    scroll-margin-top: 80px;
  }
  .project-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .project-head h2 { margin: 0; font-size: 1.4rem; }
  .meta { font-size: 0.85rem; margin: 0.35rem 0 0.75rem; }
  .lead { font-size: 1.05rem; margin-bottom: 0.85rem; }
  .project-body { margin-top: 1.25rem; }
  .project-body :global(h3:first-child) { margin-top: 0; }
  .project-links { display: flex; gap: 0.75rem; margin-top: 1.5rem; }

  .status {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .status-active { background: #dcfce7; color: #166534; }
  .status-shipped { background: #dbeafe; color: #1e40af; }
  .status-paused { background: #fef3c7; color: #92400e; }
  .status-planned { background: var(--bg-subtle); color: var(--text-muted); }
  @media (prefers-color-scheme: dark) {
    .status-active { background: #14331f; color: #4ade80; }
    .status-shipped { background: #15233b; color: #7db0ff; }
    .status-paused { background: #3a2e10; color: #fbbf24; }
  }
</style>
